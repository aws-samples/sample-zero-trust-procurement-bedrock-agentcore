# .env.demo.example
# This file shows the keys generated by `make setup`.
# The real .env.demo is auto-generated — never edit it manually.
# Cognito tokens expire hourly — re-run `make setup` to refresh.

# ─── Cognito ──────────────────────────────────────────────────────────────────
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_TOKEN_ENDPOINT=
COGNITO_OIDC_DISCOVERY_URL=

# ─── DynamoDB ─────────────────────────────────────────────────────────────────
INVOICES_TABLE_NAME=

# ─── IAM Execution Roles ──────────────────────────────────────────────────────
ORCHESTRATOR_EXECUTION_ROLE_ARN=
VENDOR_EXECUTION_ROLE_ARN=
APPROVAL_EXECUTION_ROLE_ARN=

# ─── Cognito Tokens (expire hourly — re-run make setup) ───────────────────────
ADMIN_ID_TOKEN=
ADMIN_ACCESS_TOKEN=
OPERATOR_ID_TOKEN=
OPERATOR_ACCESS_TOKEN=

# ─── Lambda ARNs — OrchestratorStack ──────────────────────────────────────────
READ_INVOICE_FN_ARN=
SHOW_IDENTITY_FN_ARN=
ROUTE_AGENT_FN_ARN=
PROCUREMENT_GATEWAY_SERVICE_ROLE_ARN=

# ─── Lambda ARNs — VendorStack ────────────────────────────────────────────────
VALIDATE_VENDOR_FN_ARN=
GET_VENDOR_TERMS_FN_ARN=

# ─── Lambda ARNs — ApprovalStack ──────────────────────────────────────────────
APPROVE_PAYMENT_FN_ARN=
GET_APPROVAL_STATUS_FN_ARN=

# ─── AgentCore Resources ──────────────────────────────────────────────────────
ORCHESTRATOR_RUNTIME_ARN=
ORCHESTRATOR_WORKLOAD_IDENTITY_ARN=
VENDOR_RUNTIME_ARN=
VENDOR_WORKLOAD_IDENTITY_ARN=
APPROVAL_RUNTIME_ARN=
APPROVAL_WORKLOAD_IDENTITY_ARN=
PROCUREMENT_GATEWAY_ID=
PROCUREMENT_GATEWAY_URL=
PROCUREMENT_GATEWAY_ARN=
PROCUREMENT_POLICY_ENGINE_ID=

# ─── Phase 5 Gateway ──────────────────────────────────────────────────────────
PHASE5_GATEWAY_ID=
PHASE5_GATEWAY_URL=
PHASE5_GATEWAY_ARN=
PHASE5_POLICY_ENGINE_ID=
